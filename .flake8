[flake8]
max-line-length = 88
ignore = E501,W503,W504,E203,E302,E305,F401,E226,F841
exclude = 
    .venv,
    __pycache__,
    *.pyc,
    migrations,
    venv,
    env,
    .git,
    delete_test_sales_final.py,
    clear_all_sales.py,
    format_code.py
per-file-ignores =
    __init__.py:F401
    check_columns.py:E402
    check_excel.py:E402
    debt_scheduler.py:E402
    run_hosting_bot.py:E402
    run_telegram_bot.py:E402